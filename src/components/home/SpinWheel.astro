<!--
  作用：鸟类趣味转盘 Astro 组件（PRD 第 5.3.1 章）
  - 封装 spinwheel.ts 核心逻辑为 Astro 组件
  - 数据源从文章 Markdown frontmatter 动态读取（通过 Astro.props 传入）
  - 转盘上方显示「我是什么鸟？」浮动对话气泡
  - 点击转盘中心区域触发旋转
  - 旋转结束后弹出对应鸟类科普文章悬浮卡片

  关联文件：
  - src/scripts/spinwheel.ts（核心转盘 JS 逻辑，沿用旧版代码）
  - src/components/home/ExploreSection.astro（父组件，注入文章数据）
  - src/utils/content.ts（getRandomArticles 获取随机文章）

  数据流：
  - Astro 服务端 getRandomArticles(8) → props.articles → window.__SPIN_WHEEL_ARTICLES__
  - 客户端 SpinWheel 类读取 window.__SPIN_WHEEL_ARTICLES__ 初始化转盘
-->

---
interface ArticleData {
  title: string;
  summary: string;
  href: string;
  emoji?: string;
}

interface Props {
  /** 转盘分区文章数据（8 篇随机文章） */
  articles?: ArticleData[];
}

const { articles = [] } = Astro.props;
---

<div class="flex flex-col items-center" id="spinwheel-container">
  <!--
    浮动对话气泡（PRD 第 5.3.1 章）
    作用：「我是什么鸟？」提示气泡，柔和 easing 缓动动画
  -->
  <div class="relative mb-6">
    <div class="animate-float bg-white px-5 py-3 rounded-2xl shadow-card border border-neutral-divider text-center">
      <span class="text-sm font-medium text-neutral-text-body">我是什么鸟？</span>
    </div>
    <!-- 气泡三角尾巴 -->
    <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-0 h-0 border-l-8 border-r-8 border-t-8 border-l-transparent border-r-transparent border-t-white"></div>
  </div>

  <!-- 转盘 Canvas -->
  <canvas
    id="spinwheel-canvas"
    width="320"
    height="320"
    class="cursor-pointer"
    aria-label="鸟类趣味转盘"
  ></canvas>

  <!--
    点击提示
    作用：引导用户点击转盘中心
  -->
  <p class="mt-4 text-xs text-neutral-text-secondary">
    点击转盘中心旋转 🎯
  </p>

  <!--
    转盘结果弹窗
    作用：旋转结束后显示对应鸟类科普文章卡片
  -->
  <div
    id="spinwheel-result-modal"
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm hidden"
  >
    <div class="bg-white rounded-card shadow-lightbox p-8 max-w-sm w-full mx-4 card-active">
      <div class="text-center mb-4">
        <span id="spinwheel-result-emoji" class="text-5xl">🐦</span>
      </div>
      <h4 id="spinwheel-result-title" class="text-lg font-bold text-neutral-text-heading mb-2 text-center">
        <!-- 动态填充 -->
      </h4>
      <p id="spinwheel-result-summary" class="text-sm text-neutral-text-secondary mb-6 text-center">
        <!-- 动态填充 -->
      </p>
      <div class="flex gap-3">
        <a
          id="spinwheel-result-link"
          href="#"
          class="flex-1 text-center px-4 py-2 bg-brand-green text-white rounded-button card-hover text-sm font-medium"
        >
          查看详情 →
        </a>
        <button
          id="spinwheel-result-close"
          class="px-4 py-2 border border-neutral-divider rounded-button text-sm text-neutral-text-secondary hover:bg-neutral-bg transition-colors"
        >
          关闭
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { SpinWheel } from '../../scripts/spinwheel';

  // 从 Astro props 注入文章数据
  const wheelArticles = (window as any).__SPIN_WHEEL_ARTICLES__ || [];

  const canvas = document.getElementById('spinwheel-canvas') as HTMLCanvasElement;
  if (canvas) {
    const wheel = new SpinWheel(canvas, wheelArticles);

    // 点击转盘中心区域触发旋转（整个 canvas 可点击）
    canvas.addEventListener('click', () => {
      wheel.spin();
    });

    // 监听旋转结束事件，弹出结果卡片
    window.addEventListener('spinwheel-result', ((e: CustomEvent) => {
      const { article } = e.detail;
      if (!article) return;

      // 填充弹窗内容
      const emojiEl = document.getElementById('spinwheel-result-emoji');
      const titleEl = document.getElementById('spinwheel-result-title');
      const summaryEl = document.getElementById('spinwheel-result-summary');
      const linkEl = document.getElementById('spinwheel-result-link') as HTMLAnchorElement;
      const modal = document.getElementById('spinwheel-result-modal');

      if (emojiEl) emojiEl.textContent = article.emoji || '🐦';
      if (titleEl) titleEl.textContent = article.title;
      if (summaryEl) summaryEl.textContent = article.summary;
      if (linkEl) linkEl.href = article.href;
      if (modal) modal.classList.remove('hidden');
    }) as EventListener);

    // 关闭弹窗
    document.getElementById('spinwheel-result-close')?.addEventListener('click', () => {
      document.getElementById('spinwheel-result-modal')?.classList.add('hidden');
    });

    // 点击遮罩关闭
    document.getElementById('spinwheel-result-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) {
        (e.currentTarget as HTMLElement).classList.add('hidden');
      }
    });
  }
</script>
